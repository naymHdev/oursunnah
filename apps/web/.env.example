# NextAuth
AUTH_SECRET=change_me_run_npx_auth_secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Backend
API_URL=http://localhost:5000
INTERNAL_API_SECRET=change_me_internal_secret

# Public backend URL — used by the browser (Redux/RTK Query). Must be
# reachable from the client, unlike API_URL above which is server-only.
NEXT_PUBLIC_API_URL=http://localhost:5001

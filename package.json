{
  "name": "our-sunnah",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @our-sunnah/database run generate",
    "db:migrate": "pnpm --filter @our-sunnah/database run migrate",
    "db:studio": "pnpm --filter @our-sunnah/database run studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
